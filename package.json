{
	"name": "nekoshare",
	"private": true,
	"scripts": {
		"build": "turbo run build",
		"build:server": "turbo run build --filter=server",
		"build:desktop": "turbo run build --filter=desktop",
		"build:lib-nksocket": "cargo build-lib-nksocket",
		"dev": "turbo run dev",
		"dev:server": "turbo run dev --filter=server",
		"dev:desktop": "turbo run dev --filter=desktop --filter=server",
		"lint": "turbo run lint",
		"format": "prettier --write \"**/*.{ts,tsx,md}\"",
		"check-types": "turbo run check-types"
	},
	"devDependencies": {
		"prettier": "^3.6.2",
		"turbo": "^2.6.1",
		"typescript": "5.9.3"
	},
	"packageManager": "pnpm@10.15.0",
	"engines": {
		"node": ">=18"
	}
}
